# Credenciais do widget de clima (calendar/weather.sh).
# Copie para `.env` na mesma pasta e preencha — o .env real não é versionado.
#
#   cp .env.example .env
#
# Sem a chave, o widget cai num fallback com dados zerados ("No API Key").

# Chave da API do OpenWeatherMap (https://openweathermap.org/api - o plano free serve)
OPENWEATHER_KEY=

# ID numérico da sua cidade no OpenWeatherMap.
# Busque em https://openweathermap.org/find e pegue o ID da URL.
OPENWEATHER_CITY_ID=

# metric (°C) | imperial (°F) | standard (K). Default: metric
OPENWEATHER_UNIT=metric
